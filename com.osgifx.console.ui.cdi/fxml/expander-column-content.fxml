<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>

<TabPane fx:id="rootPane" prefHeight="400.0" prefWidth="600.0" tabClosingPolicy="UNAVAILABLE" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.osgifx.console.ui.cdi.CdiDetailsFxController">
  <tabs>
    <Tab text="Info">
      <content>
        <BorderPane fx:id="infoPane" prefHeight="200.0" prefWidth="200.0" />
      </content>
    </Tab>
    <Tab text="Components">
      <content>
        <TableView fx:id="componentsTable" prefHeight="200.0" prefWidth="200.0">
          <columns>
            <TableColumn fx:id="componentNameColumn" prefWidth="250.0" text="Name" />
            <TableColumn fx:id="componentTypeColumn" prefWidth="150.0" text="Type" />
            <TableColumn fx:id="componentEnabledColumn" prefWidth="100.0" text="Enabled" />
          </columns>
        </TableView>
      </content>
    </Tab>
    <Tab text="Extensions">
      <content>
        <TableView fx:id="extensionsTable" prefHeight="200.0" prefWidth="200.0">
          <columns>
            <TableColumn fx:id="extensionServiceIdColumn" prefWidth="150.0" text="Service ID" />
            <TableColumn fx:id="extensionFilterColumn" prefWidth="400.0" text="Service Filter" />
          </columns>
        </TableView>
      </content>
    </Tab>
    <Tab text="Errors">
      <content>
        <ListView fx:id="errorsList" prefHeight="200.0" prefWidth="200.0" />
      </content>
    </Tab>
  </tabs>
</TabPane>
