<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>

<TabPane fx:id="rootPane" prefHeight="400.0" prefWidth="600.0" tabClosingPolicy="UNAVAILABLE" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.osgifx.console.ui.cdi.CdiDetailsFxController">
  <tabs>
    <Tab text="Info">
      <content>
        <BorderPane fx:id="infoPane" prefHeight="200.0" prefWidth="200.0" />
      </content>
    </Tab>
    <Tab text="Components">
      <content>
        <TableView style="-fx-table-cell-border-color: transparent;" fx:id="componentsTable">
          <columns>
            <TableColumn fx:id="componentNameColumn" text="Name" />
            <TableColumn fx:id="componentTypeColumn" text="Type" />
            <TableColumn fx:id="componentEnabledColumn" text="Enabled" />
          </columns>
          <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_ALL_COLUMNS" />
          </columnResizePolicy>
        </TableView>
      </content>
    </Tab>
    <Tab text="Extensions">
      <content>
        <TableView style="-fx-table-cell-border-color: transparent;" fx:id="extensionsTable">
          <columns>
            <TableColumn fx:id="extensionServiceIdColumn" text="Service ID" />
            <TableColumn fx:id="extensionFilterColumn" text="Service Filter" />
          </columns>
          <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_ALL_COLUMNS" />
          </columnResizePolicy>
        </TableView>
      </content>
    </Tab>
    <Tab text="Errors">
      <content>
        <ListView fx:id="errorsList" prefHeight="200.0" prefWidth="200.0" />
      </content>
    </Tab>
  </tabs>
</TabPane>
