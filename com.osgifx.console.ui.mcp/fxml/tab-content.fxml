<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane fx:id="root" prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.osgifx.console.ui.mcp.McpFxController">
   <top>
      <HBox alignment="CENTER_LEFT" spacing="5.0" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="actionButton" mnemonicParsing="false" text="Start MCP Server" />
            <Button fx:id="refreshLogsButton" mnemonicParsing="false" onAction="#refreshLogs" text="Refresh Logs" />
            <Button fx:id="clearLogsButton" mnemonicParsing="false" onAction="#clearLogs" text="Clear Logs" />
            <Button fx:id="configInfoButton" mnemonicParsing="false" onAction="#showConfigInfo" text="Configuration Info" />
            <Label fx:id="statusLabel" text="Status: STOPPED" />
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </HBox>
   </top>
   <center>
      <TabPane tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER">
        <tabs>
          <Tab text="Tools">
               <content>
                  <TableView style="-fx-table-cell-border-color: transparent;" fx:id="toolsTable">
                    <columns>
                      <TableColumn fx:id="nameColumn" text="Tool Name" />
                      <TableColumn fx:id="descriptionColumn" text="Description" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_ALL_COLUMNS" />
                     </columnResizePolicy>
                  </TableView>
               </content>
          </Tab>
          <Tab text="Logs">
               <content>
                  <TableView style="-fx-table-cell-border-color: transparent;" fx:id="logsTable">
                    <columns>
                      <TableColumn style="-fx-alignment: CENTER;" fx:id="timestampColumn" text="Timestamp" />
                      <TableColumn style="-fx-alignment: CENTER;" fx:id="typeColumn" text="Tool" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_ALL_COLUMNS" />
                     </columnResizePolicy>
                  </TableView>
               </content>
          </Tab>
        </tabs>
      </TabPane>
   </center>
</BorderPane>
