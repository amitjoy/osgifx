<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.osgifx.console.ui.threads.ThreadDumpOptionsDialogController"
      spacing="20" prefWidth="550">
    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <!-- Statistics Section -->
    <VBox spacing="10">
        <Label text="Statistics" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
        <Separator/>

        <GridPane hgap="15" vgap="10">
            <padding>
                <Insets left="5"/>
            </padding>

            <Label text="Estimated Size:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <Label fx:id="threadDumpSizeLabel" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>

            <Label text="Estimated Compressed:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <Label fx:id="compressedSizeLabel" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>

            <Label text="Transport:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <HBox fx:id="transportBox" spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

            <columnConstraints>
                <ColumnConstraints hgrow="NEVER" minWidth="160"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>
        </GridPane>

        <Label fx:id="warningLabel" managed="false" visible="false" wrapText="true"
               style="-fx-text-fill: #d97706; -fx-font-weight: bold; -fx-padding: 10 0 0 5;"/>
    </VBox>

    <!-- Options Section -->
    <VBox spacing="10">
        <Label text="Capture Options" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
        <Separator/>

        <VBox fx:id="optionsContainer" spacing="15">
            <padding>
                <Insets left="5"/>
            </padding>
        </VBox>

        <VBox fx:id="infoBox" spacing="8" managed="false" visible="false"
              style="-fx-background-color: #fef3c7; -fx-padding: 12; -fx-border-color: #f59e0b; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4;">
            <Label text="⚠️ No LargePayloadHandler Available" style="-fx-font-weight: bold; -fx-text-fill: #92400e;"/>
            <Label text="Consider implementing a LargePayloadHandler service to enable automatic upload/storage, or store the thread dump locally on the agent and retrieve it manually via SFTP/SCP."
                   wrapText="true" style="-fx-text-fill: #92400e;"/>
        </VBox>
    </VBox>
</VBox>
