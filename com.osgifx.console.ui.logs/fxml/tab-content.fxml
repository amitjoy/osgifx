<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import org.controlsfx.control.SegmentedButton?>

<BorderPane fx:id="mainPane" prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.osgifx.console.ui.logs.StarterFxController">
   <top>
      <HBox alignment="CENTER_LEFT" spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="8.0" left="10.0" right="10.0" top="8.0" />
         </padding>
         <SegmentedButton fx:id="logsActionTypeButton">
            <buttons>
               <ToggleButton fx:id="logsViewButton" selected="true" text="Log Events" />
               <ToggleButton fx:id="configurationsViewButton" text="OSGi R7 Log Configurations" />
            </buttons>
         </SegmentedButton>
         <Region HBox.hgrow="ALWAYS" />
         <Button fx:id="clearLogsButton" mnemonicParsing="false" onAction="#clearLogs" text="Clear Logs" />
         <Button fx:id="toggleLogReceiveButton" mnemonicParsing="false" onAction="#toggleLogReceive" text="Start Displaying Logs" />
      </HBox>
   </top>
</BorderPane>
