Bundle-Name           : OSGi.fx RSA Agent Mock Topology
Bundle-Description    : Mocks Remote Service Admin endpoints in the target framework for OSGi.fx UI testing
javac.source          : 1.8
javac.target          : ${javac.source}
javac.compliance      : ${javac.source}
-buildpath            : \
                        osgi.annotation,\
                        osgi.core;version='6.0.0',\
                        osgi.cmpn;version='6.0.0'
-privatepackage       : \
                        com.osgifx.console.agent.rsa.mock
