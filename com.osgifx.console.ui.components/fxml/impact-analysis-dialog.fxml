<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.controlsfx.control.*?>
<?import org.controlsfx.glyphfont.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.osgifx.console.ui.components.dialog.ImpactAnalysisDialogController"
      spacing="15" prefWidth="700" prefHeight="500">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: #f8fafc; -fx-padding: 15; -fx-background-radius: 8;">
        <Glyph fx:id="headerIcon" fontFamily="FontAwesome" icon="SHIELD" fontSize="32" style="-fx-text-fill: #3b82f6;"/>
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label fx:id="headerLabel" text="Impact Analysis" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #1e293b;"/>
            <Label fx:id="summaryLabel" wrapText="true" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
        </VBox>
    </HBox>

    <StackPane VBox.vgrow="ALWAYS" style="-fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 8;">
        <VBox>
            <TableView fx:id="impactTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="affectedItemColumn" prefWidth="450.0" text="Affected Item" />
                    <TableColumn fx:id="impactTypeColumn" prefWidth="150.0" text="Impact Type" />
                </columns>
                <placeholder>
                    <Label text="No impacts detected" style="-fx-text-fill: #94a3b8;"/>
                </placeholder>
            </TableView>
            <VBox spacing="5.0" style="-fx-background-color: #f9fafb; -fx-border-color: #e5e7eb; -fx-border-width: 1 0 0 0; -fx-padding: 10;">
                <Label style="-fx-font-weight: bold; -fx-text-fill: #374151;" text="Impact Description" />
                <Label fx:id="descriptionLabel" style="-fx-text-fill: #4b5563;" wrapText="true" />
            </VBox>
        </VBox>
        <MaskerPane fx:id="maskerPane" text="Analyzing Impacts..." visible="false"/>
    </StackPane>

</VBox>
