-buildpath          : \
                      ${bundles.required},\
                      com.google.gson,\
                      io.fusionauth:java-http;packages=*,\
                      org.osgi.util.converter
-privatepackage     : com.osgifx.console.mcp.*
-conditionalpackage : io.fusionauth*
-fixupmessages      : 'split'
-testpath           : \
                      osgi.enroute.junit.wrapper,\
                      osgi.enroute.hamcrest.wrapper